{
  "name": "vscode-extension-ts-boilerplate",
  "displayName": "VSCode Extension Ts Boilerplate",
  "description": "VSCode Extension Ts Boilerplate is a TypeScript-based template for building VS Code extensions with a fully configured development environment and a clean layered architecture ready to extend.",
  "version": "1.0.0",
  "private": true,
  "publisher": "DieLibonati",
  "icon": "public/icon.png",
  "engines": {
    "vscode": "^1.99.0",
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DiegoLibonati/vscode-extension-ts-boilerplate"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-extension-ts-boilerplate.alive",
        "title": "VSCode Extension Ts Boilerplate: Alive"
      }
    ],
    "configuration": {
      "title": "VSCode Extension Ts Boilerplate",
      "properties": {}
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "check-types": "tsc --build --verbose",
    "check-types:app": "tsc --build tsconfig.app.json --verbose",
    "check-types:test": "tsc --build tsconfig.test.json --verbose",
    "watch:app": "tsc --build tsconfig.app.json --watch",
    "watch:test": "tsc --build tsconfig.test.json --watch",
    "dev": "tsx scripts/build.ts --watch",
    "build": "tsx scripts/build.ts --production",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:all": "eslint src __tests__ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:all": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "jest --verbose",
    "test:watch": "jest --watchAll --verbose",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.99.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0"
  }
}
